{
  "type": "code-review",
  "description": "代码审查：基于 git commit 的只读审查，按提交者分组，只报告高风险问题",
  "defaultAgent": "claude",
  "defaultMaxRetries": 2,
  "defaultBudgetUsd": 10.0,
  "phases": [
    {
      "name": "execute",
      "template": "tasks/templates/code-review.md",
      "allowedTools": [
        "Read", "Write", "Glob", "Grep",
        "Bash(git log*)", "Bash(git diff*)", "Bash(git show*)",
        "Bash(git status*)", "Bash(git pull*)"
      ]
    }
  ]
}
